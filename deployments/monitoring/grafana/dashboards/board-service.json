      "id": 9,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] }
      },
      "title": "Ошибки по методу и коду",
      "description": "gRPC ошибки в секунду, сгруппированные по методу и коду ответа",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(board_grpc_requests_total{code!=\"OK\"}[1m])) by (method, code)",
          "legendFormat": "{{ method }} [{{ code }}]",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
