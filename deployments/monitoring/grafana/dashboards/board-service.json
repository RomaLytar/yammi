      "id": 8,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] }
      },
      "title": "Запросы по методу",
      "description": "gRPC запросы в секунду, сгруппированные по методу (stacked)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(board_grpc_requests_total[1m])) by (method)",
          "legendFormat": "{{ method }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
