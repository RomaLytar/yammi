{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Row 1: Operations (counters)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Board Operations Total",
      "description": "Total operations counter by method type",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(board_operations_total{method=\"create\"}[1m])", "legendFormat": "create (green)" },
        { "expr": "rate(board_operations_total{method=\"get\"}[1m])", "legendFormat": "get (blue)" },
        { "expr": "rate(board_operations_total{method=\"list\"}[1m])", "legendFormat": "list (yellow)" },
        { "expr": "rate(board_operations_total{method=\"update\"}[1m])", "legendFormat": "update (orange)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 7 },
      "id": 2,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Card Operations Total",
      "description": "Card move operations counter",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(card_operations_total{method=\"move\"}[1m])", "legendFormat": "move (purple)" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Row 2: Latency (histograms, p50/p95/p99)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "id": 3,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Board Query Latency - Get Board",
      "description": "Query duration for get_board operation (p50, p95, p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "board_query_duration_seconds{query=\"get_board\",quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "board_query_duration_seconds{query=\"get_board\",quantile=\"0.95\"}", "legendFormat": "p95 (threshold: yellow > 200ms, red > 500ms)" },
        { "expr": "board_query_duration_seconds{query=\"get_board\",quantile=\"0.99\"}", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "id": 4,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Card Move Latency - p95",
      "description": "p95 query duration for move_card operation with thresholds",
      "type": "timeseries",
      "targets": [
        { "expr": "board_query_duration_seconds{query=\"move_card\",quantile=\"0.95\"}", "legendFormat": "p95 move_card" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Row 3: Cache & Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 21 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Board Cache Hit Ratio",
      "description": "Cache hit ratio gauge (0-100%, green > 70%, yellow 50-70%, red < 50%)",
      "type": "stat",
      "targets": [
        { "expr": "board_cache_hit_ratio", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 21 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Optimistic Lock Conflicts",
      "description": "Conflicts total (red threshold > 100/min)",
      "type": "stat",
      "targets": [
        { "expr": "rate(board_optimistic_lock_conflicts_total[1m])", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 21 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Repository Errors",
      "description": "Total repository errors (red if > 0)",
      "type": "stat",
      "targets": [
        { "expr": "rate(board_repository_errors_total[1m])", "legendFormat": "" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 103,
      "title": "Row 4: Database (PgBouncer, когда будет)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 27 },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "PgBouncer Active Connections",
      "description": "Active database connections to Board Service DB",
      "type": "stat",
      "targets": [
        { "expr": "pgbouncer_active_connections{database=\"board_service\"}", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 27 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "PgBouncer Waiting Clients",
      "description": "Waiting clients count (yellow > 10, red > 50)",
      "type": "stat",
      "targets": [
        { "expr": "pgbouncer_waiting_clients{database=\"board_service\"}", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "PgBouncer Connection Pool Status",
      "description": "Active and waiting connections trend over time",
      "type": "timeseries",
      "targets": [
        { "expr": "pgbouncer_active_connections{database=\"board_service\"}", "legendFormat": "active" },
        { "expr": "pgbouncer_waiting_clients{database=\"board_service\"}", "legendFormat": "waiting" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["board-service", "operations", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Board Service",
  "uid": "board-service",
  "version": 1
}
