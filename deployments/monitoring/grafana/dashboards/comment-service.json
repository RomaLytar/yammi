      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(comment_grpc_request_duration_seconds_bucket[1m])) by (le)) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(comment_grpc_request_duration_seconds_bucket[1m])) by (le)) * 1000", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(comment_grpc_request_duration_seconds_bucket[1m])) by (le)) * 1000", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
