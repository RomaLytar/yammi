      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Ошибки публикации",
      "description": "Ошибки публикации событий в NATS (red если > 0)",
      "type": "stat",
      "targets": [
        { "expr": "sum(comment_event_publish_errors_total)", "legendFormat": "" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 8,
      "title": "gRPC Трафик",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
