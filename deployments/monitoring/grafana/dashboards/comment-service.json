      "title": "Запросы по методу",
      "description": "Скорость gRPC запросов по методу (stacked)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(comment_grpc_requests_total[1m])) by (method)", "legendFormat": "{{ method }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
