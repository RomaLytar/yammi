{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Обзор сервера",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Подключения",
      "description": "Активные TCP-подключения к NATS",
      "type": "stat",
      "targets": [{ "expr": "gnatsd_varz_connections", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Память",
      "description": "RAM используемая NATS сервером",
      "type": "stat",
      "targets": [{ "expr": "gnatsd_varz_mem", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU",
      "type": "stat",
      "targets": [{ "expr": "gnatsd_varz_cpu", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Потоки",
      "type": "stat",
      "targets": [{ "expr": "jetstream_server_total_streams", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Consumers",
      "description": "Durable consumers подписанные на потоки",
      "type": "stat",
      "targets": [{ "expr": "jetstream_server_total_consumers", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Хранилище",
      "description": "Место на диске занятое JetStream потоками",
      "type": "stat",
      "targets": [{ "expr": "jetstream_account_storage_used", "legendFormat": "" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 8,
      "title": "Поток сообщений",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Сообщения вход/выход (msg/s)",
      "description": "Входящие -- от сервисов в NATS. Исходящие -- из NATS к consumers",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(gnatsd_varz_in_msgs[1m])", "legendFormat": "Входящие (от сервисов)" },
        { "expr": "rate(gnatsd_varz_out_msgs[1m])", "legendFormat": "Исходящие (к consumers)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Байты вход/выход (bytes/s)",
      "description": "Объём данных проходящих через NATS",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(gnatsd_varz_in_bytes[1m])", "legendFormat": "Входящие байты" },
        { "expr": "rate(gnatsd_varz_out_bytes[1m])", "legendFormat": "Исходящие байты" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 11,
      "title": "Потоки (Streams)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 12,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "USERS",
      "description": "Сообщений в потоке USERS (user.created, user.deleted)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"USERS\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "id": 13,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "BOARDS",
      "description": "Сообщений в потоке BOARDS (board.*, column.*, card.*, member.*)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"BOARDS\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "id": 14,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "NOTIFICATIONS",
      "description": "Сообщений в потоке NOTIFICATIONS (notification.created)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"NOTIFICATIONS\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "id": 15,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "DLQ (ошибки)",
      "description": "Dead Letter Queue -- сообщения которые не удалось обработать после 7 попыток. Должно быть 0",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"DLQ\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 18 },
      "id": 16,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Рост сообщений в потоках",
      "description": "Динамика количества сообщений во всех потоках",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_stream_total_messages{stream_name=\"USERS\"}", "legendFormat": "USERS" },
        { "expr": "jetstream_stream_total_messages{stream_name=\"BOARDS\"}", "legendFormat": "BOARDS" },
        { "expr": "jetstream_stream_total_messages{stream_name=\"NOTIFICATIONS\"}", "legendFormat": "NOTIFICATIONS" },
        { "expr": "jetstream_stream_total_messages{stream_name=\"DLQ\"}", "legendFormat": "DLQ" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 17,
      "title": "Consumers -- здоровье",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 26 },
      "id": 18,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Необработанные сообщения (pending)",
      "description": "Сколько сообщений ждут обработки каждым consumer. Если растёт -- consumer не успевает",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_pending", "legendFormat": "{{ consumer_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 26 },
      "id": 19,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Ожидают подтверждения (ack pending)",
      "description": "Доставлены consumer-у, но ещё не подтверждены (Ack). Если близко к MaxAckPending -- backpressure",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_ack_pending", "legendFormat": "{{ consumer_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 26 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Скорость повторных доставок (redelivery/s)",
      "description": "Если > 0 -- что-то постоянно не обрабатывается",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(jetstream_consumer_num_redelivered[1m])) by (consumer_name)", "legendFormat": "{{ consumer_name }}" }
      ]
    },

    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 21,
      "title": "Пайплайн удаления пользователей",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
          "id": 22,
          "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
          "title": "USERS stream: last_seq vs delivered_seq",
          "description": "Разница между last_seq и delivered_seq показывает отставание consumer-а user-service-user-deleted-v1",
          "type": "timeseries",
          "targets": [
            { "expr": "jetstream_stream_last_seq{stream_name=\"USERS\"}", "legendFormat": "stream last_seq (опубликовано)" },
            { "expr": "jetstream_consumer_delivered_stream_seq{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "delivered_seq (обработано)" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
          "id": 23,
          "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
          "title": "Pending + Ack Pending (user-deleted)",
          "description": "Pending = ещё не доставлено. Ack Pending = доставлено, ждёт подтверждения",
          "type": "timeseries",
          "targets": [
            { "expr": "jetstream_consumer_num_pending{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "pending" },
            { "expr": "jetstream_consumer_num_ack_pending{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "ack pending" }
          ]
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" } },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
          "id": 24,
          "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
          "title": "Redelivery rate (user-deleted)",
          "description": "Скорость повторных доставок для consumer-а user-service-user-deleted-v1",
          "type": "timeseries",
          "targets": [
            { "expr": "rate(jetstream_consumer_num_redelivered{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}[1m])", "legendFormat": "redelivery/s" }
          ]
        }
      ]
    }
  ],
  "refresh": "5s",
  "liveNow": true,
  "schemaVersion": 39,
  "tags": ["nats", "jetstream"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "NATS JetStream",
  "uid": "nats-jetstream",
  "version": 5
}
