{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "NATS Сервер",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Подключения",
      "description": "Активные TCP-подключения к NATS (сервисы: auth x5, board, notification, gateway, user, comment...)",
      "type": "stat",
      "targets": [{ "expr": "gnatsd_varz_connections", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Память",
      "description": "RAM используемая NATS сервером",
      "type": "stat",
      "targets": [{ "expr": "gnatsd_varz_mem", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent", "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU",
      "type": "stat",
      "targets": [{ "expr": "gnatsd_varz_cpu", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" } },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Поток сообщений (msg/sec)",
      "description": "Входящие — от сервисов в NATS. Исходящие — из NATS к consumers",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(gnatsd_varz_in_msgs[1m])", "legendFormat": "Входящие (от сервисов)" },
        { "expr": "rate(gnatsd_varz_out_msgs[1m])", "legendFormat": "Исходящие (к consumers)" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Потоки (Streams)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "USERS",
      "description": "Сообщений в потоке USERS (user.created и др.)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"USERS\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "BOARDS",
      "description": "Сообщений в потоке BOARDS (board.*, column.*, card.*, member.*)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"BOARDS\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "id": 12,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "NOTIFICATIONS",
      "description": "Сообщений в потоке NOTIFICATIONS (notification.created → WebSocket Gateway)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"NOTIFICATIONS\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "DLQ (ошибки)",
      "description": "Dead Letter Queue — сообщения которые не удалось обработать после 7 попыток. Должно быть 0",
      "type": "stat",
      "targets": [{ "expr": "jetstream_stream_total_messages{stream_name=\"DLQ\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 10 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Сообщений в потоках",
      "description": "Рост количества сообщений во всех потоках",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_stream_total_messages{stream_name=\"USERS\"}", "legendFormat": "USERS" },
        { "expr": "jetstream_stream_total_messages{stream_name=\"BOARDS\"}", "legendFormat": "BOARDS" },
        { "expr": "jetstream_stream_total_messages{stream_name=\"NOTIFICATIONS\"}", "legendFormat": "NOTIFICATIONS" },
        { "expr": "jetstream_stream_total_messages{stream_name=\"DLQ\"}", "legendFormat": "DLQ" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Consumers — отставание и проблемы",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Необработанные сообщения (pending)",
      "description": "Сколько сообщений ждут обработки каждым consumer'ом. Если растёт — consumer не успевает",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_pending{consumer_name=~\".*-v[2-9].*|user-service.*\"}", "legendFormat": "{{ consumer_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Ожидают подтверждения (ack pending)",
      "description": "Доставлены consumer'у, но ещё не подтверждены (Ack). MaxAckPending=500. Если близко к 500 — backpressure",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_ack_pending{consumer_name=~\".*-v[2-9].*|user-service.*\"}", "legendFormat": "{{ consumer_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Повторные доставки (redelivered)",
      "description": "Сообщения доставленные повторно из-за ошибок или таймаутов. Если растёт — consumer падает при обработке",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_redelivered{consumer_name=~\".*-v[2-9].*|user-service.*\"}", "legendFormat": "{{ consumer_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "id": 23,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Скорость повторных доставок (redelivery/sec)",
      "description": "Если > 0 — что-то постоянно не обрабатывается",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(jetstream_consumer_num_redelivered{consumer_name=~\".*-v[2-9].*|user-service.*\"}[1m])) by (consumer_name)", "legendFormat": "{{ consumer_name }}" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Хранилище",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 32 },
      "id": 30,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Диск (JetStream Storage)",
      "description": "Сколько места на диске занимают все JetStream потоки",
      "type": "stat",
      "targets": [{ "expr": "jetstream_account_storage_used", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 32 },
      "id": 31,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Всего потоков",
      "type": "stat",
      "targets": [{ "expr": "jetstream_server_total_streams", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 32 },
      "id": 32,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Всего consumers",
      "description": "Durable consumers подписанные на потоки (notification-service, gateway, cache consumers)",
      "type": "stat",
      "targets": [{ "expr": "jetstream_server_total_consumers", "legendFormat": "" }]
    }
  ],
  "refresh": "5s",
  "liveNow": true,
  "schemaVersion": 39,
  "tags": ["nats", "jetstream"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "NATS JetStream",
  "uid": "nats-jetstream",
  "version": 4
}
