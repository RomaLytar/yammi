{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Consumer: user-service-user-deleted-v1",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Pending & Ack Pending",
      "description": "Pending = ещё не доставлено. Ack Pending = доставлено, ждёт подтверждения.",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_pending{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "pending" },
        { "expr": "jetstream_consumer_num_ack_pending{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "ack pending" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Redelivered & Waiting",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_consumer_num_redelivered{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "redelivered" },
        { "expr": "jetstream_consumer_num_waiting{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "waiting" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Delivery Progress",
      "description": "delivered_stream_seq vs stream last_seq — разница = отставание consumer'а",
      "type": "timeseries",
      "targets": [
        { "expr": "jetstream_stream_last_seq{stream_name=\"USERS\"}", "legendFormat": "stream last_seq (published)" },
        { "expr": "jetstream_consumer_delivered_stream_seq{stream_name=\"USERS\",consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "deleted delivered_seq (processed)" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Delete Event Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Delete Events Published (rate)",
      "description": "Скорость публикации user.deleted событий от auth реплик",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(jetstream_stream_total_messages{stream_name=\"USERS\"}[30s])", "legendFormat": "events/s → USERS (all)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 9 }] }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Backpressure (Ack Pending)",
      "description": "Чем ближе к MaxAckPending, тем сильнее backpressure на consumer.",
      "type": "stat",
      "targets": [{ "expr": "jetstream_consumer_num_ack_pending{consumer_name=\"user-service-user-deleted-v1\"}", "legendFormat": "" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Redelivery Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(jetstream_consumer_num_redelivered{consumer_name=\"user-service-user-deleted-v1\"}[1m])", "legendFormat": "redelivery/s" }]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["nats", "jetstream", "deletion"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NATS User Deletion",
  "uid": "nats-user-deleted",
  "version": 1
}
