  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Уведомления",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] }
      },
      "title": "Уведомления пользователям (по типу)",
      "description": "Скорость доставки уведомлений пользователям, разбивка по типу события",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(notification_created_total[1m])", "legendFormat": "{{ type }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Уведомлений создано",
      "description": "Сколько уведомлений доставлено пользователям. Одно событие → уведомление каждому участнику доски (кроме автора), поэтому больше чем событий",
      "type": "stat",
      "targets": [
        { "expr": "sum(notification_created_total)", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Пропущено",
      "description": "Уведомления пропущенные из-за отключённых настроек",
      "type": "stat",
      "targets": [
        { "expr": "notification_skipped_total", "legendFormat": "" }
      ]
    },

    {
