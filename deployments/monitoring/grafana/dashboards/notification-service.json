      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Событий из NATS",
      "description": "Сколько NATS-событий обработано (board.created, card.moved и т.д.). Одно событие = одно действие пользователя",
      "type": "stat",
      "targets": [
        { "expr": "sum(notification_events_consumed_total)", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
